# ═══════════════════════════════════════════
# BASIRA_ — Environment Configuration
# ═══════════════════════════════════════════
# Copy this to .env and fill in your values

# Gemini API key for Concept Explorer
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Obsidian vault path for paper exports (optional)
# Set to your vault's root directory
VAULT_PATH=

# Vault subfolder for BASIRA_ paper exports
VAULT_BASIRA_FOLDER=basira
