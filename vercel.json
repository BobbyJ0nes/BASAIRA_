{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "src/client",
  "rewrites": [
    { "source": "/api/papers/:id/content", "destination": "/api/papers/[id]/content" },
    { "source": "/api/papers/:id/concepts", "destination": "/api/papers/[id]/concepts" },
    { "source": "/api/papers/:id/explore", "destination": "/api/papers/[id]/explore" },
    { "source": "/api/papers", "destination": "/api/papers" },
    { "source": "/api/stats", "destination": "/api/stats" },
    { "source": "/api/domains", "destination": "/api/domains" },
    { "source": "/api/tags", "destination": "/api/tags" },
    { "source": "/api/search", "destination": "/api/search" },
    { "source": "/reader.html", "destination": "/reader.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ]
}
